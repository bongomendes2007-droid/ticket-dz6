# Supabase — copie este arquivo para .env.local e preencha com as chaves reais.
# As chaves ficam em: Supabase Dashboard > Project Settings > API

# URL do projeto (publica)
NEXT_PUBLIC_SUPABASE_URL=

# Chave publishable / anon (publica — usada no navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secret / service_role (NUNCA expor no navegador — apenas server-side)
SUPABASE_SERVICE_ROLE_KEY=
